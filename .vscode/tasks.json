{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pipeline: run to ingestion",
      "type": "shell",
      "command": "bash tools/run_stack_workflow.sh --stop-at ingestion",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: run to stream-processing",
      "type": "shell",
      "command": "bash tools/run_stack_workflow.sh --stop-at stream-processing",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: run to batch",
      "type": "shell",
      "command": "bash tools/run_stack_workflow.sh --stop-at batch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: run to analytics",
      "type": "shell",
      "command": "bash tools/run_stack_workflow.sh --stop-at analytics",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "pipeline: run to ml",
      "type": "shell",
      "command": "bash tools/run_stack_workflow.sh --stop-at ml",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "compose: up -d",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "compose: down",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "compose: down -v",
      "type": "shell",
      "command": "docker compose down -v --remove-orphans && docker volume prune -f && bash tools/reset_local_state.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "test: unit",
      "type": "shell",
      "command": "python3 -m unittest discover -s tests/unit -p 'test_*.py'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "test: integration",
      "type": "shell",
      "command": "python3 -m unittest discover -s tests/integration -p 'test_*.py'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
